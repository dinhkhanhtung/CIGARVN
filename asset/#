        $(document).on('click', '#trigger-load-less-button', function(e) {
            e.preventDefault();
            var visibleItems = 0;

            if (window.innerWidth > 1680 && window.innerWidth <= 2000) {
                visibleItems = 13;
            } else if (window.innerWidth > 520 && window.innerWidth <= 1680) {
