{
  "rewrites": [
    { "source": "/san-pham/detail", "destination": "/san-pham/detail/" },
    { "source": "/san-pham/detail/(.*)", "destination": "/san-pham/detail/?$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
